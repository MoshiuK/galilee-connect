# ============================================
# Galilee Connect - Configuration
# ============================================
# Copy this file to .env and fill in your values

# Server
PORT=3000
HOST=0.0.0.0
BASE_URL=http://localhost:3000
# App base URL for outbound links (reset emails, notifications, etc.)
# Set this to your production domain (e.g. https://study.galileembchurch.com)
# Falls back to BASE_URL if not set
APP_BASE_URL=

# Admin Auth
ADMIN_USERNAME=pastor
ADMIN_PASSWORD=galilee2024
ADMIN_EMAIL=your-admin-email@example.com
SESSION_SECRET=change-this-to-a-random-string

# Database
DB_PATH=./data/galilee.db

# Timezone (for scheduling)
TIMEZONE=America/Chicago

# Daily notification send time (24hr format)
SEND_HOUR=8
SEND_MINUTE=0

# Email (SMTP)
EMAIL_ENABLED=true
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM_NAME=Galilee Missionary Baptist Church
EMAIL_FROM_ADDRESS=your-email@gmail.com

# SMS (Twilio) - Optional
SMS_ENABLED=false
TWILIO_ACCOUNT_SID=your-account-sid
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# Bible API
BIBLE_API_URL=https://bible-api.com

# Church Info
CHURCH_NAME=Galilee Missionary Baptist Church
CHURCH_PASTOR=Pastor Moshiu Knox
CHURCH_CITY=Florence, Alabama
CHURCH_PHONE=(256) 555-0100
CHURCH_EMAIL=info@galileembc.org
